# Night Ninjas — Shadow Tracker · npm config
#
# legacy-peer-deps=true
# ---------------------
# This project uses React 19 RC (specific commit-pinned prerelease) while
# some dependencies (notably drizzle-orm) declare peerDependencies as
# react@">=18". npm 11+ enforces peer-dep semver strictly, and prerelease
# versions like 19.0.0-rc-... are NOT considered to satisfy >=18 under
# strict semver rules.
#
# Without this flag, `npm install` fails with ERESOLVE on a clean install.
# The runtime behavior is fine — these are warning-level constraints —
# so we set legacy-peer-deps to revert to npm 6's lenient resolver.
#
# fund=false / audit=false
# ------------------------
# Cuts npm install noise. Vulnerability auditing happens via GitHub
# Dependabot at the repo level (when this project gets one).

legacy-peer-deps=true
fund=false
audit=false
