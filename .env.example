# Night Ninjas — Shadow Tracker
# Copy this file to .env.local and adjust as needed.
# No values are required to start — the wizard captures Strava credentials
# at runtime and stores them in the OS keychain, not in env vars.

# Disable Next.js telemetry (we are local-first, but Next phones home by default)
NEXT_TELEMETRY_DISABLED=1

# Optional: override the default data directory location.
# Defaults: %APPDATA%\NightNinjas (Windows), ~/.night-ninjas (Mac/Linux)
# NN_DATA_DIR=

# Optional: override the OAuth callback port (default 3000 — same as dev server)
# NN_OAUTH_PORT=3000
